# Force LF line endings for shell scripts and configs (Linux VM compatibility)
*.sh text eol=lf
*.conf text eol=lf
Dockerfile* text eol=lf
docker-compose*.yml text eol=lf
.env.example text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
