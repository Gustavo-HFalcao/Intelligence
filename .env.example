# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_key_aqui
SUPABASE_KEY=sua_anon_key_aqui

# ── App ───────────────────────────────────────────────────────────────────────
# URL pública da VM (sem barra no final)
APP_URL=https://SEU_DOMINIO

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET_KEY=troque_por_uma_string_aleatoria_longa

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_VISION_KEY=sk-...

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
RDO_EMAIL_USER=seu@gmail.com
RDO_EMAIL_PASSWORD=sua_app_password_gmail

# ── Redis (definido automaticamente pelo docker-compose) ──────────────────────
REDIS_URL=redis://redis:6379/0

# ── Twilio WhatsApp (opcional) ────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
